{
  "name": "connpass-fukuoka-events-bluesky-bot",
  "version": "0.0.0",
  "private": true,
  "description": "Bluesky bot that posts new connpass events held in Fukuoka prefecture",
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atproto/api": "0.19.16"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=26.1.0"
  },
  "packageManager": "pnpm@11.0.8"
}
